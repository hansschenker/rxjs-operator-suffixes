{
  "name": "rxjs-dom",
  "version": "0.1.0",
  "description": "Fine-grained DOM text bindings powered by a TypeScript template tag and RxJS state streams.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "rxjs",
    "dom",
    "template-literals",
    "fine-grained-reactivity",
    "bindings"
  ],
  "license": "MIT"
}
{
  "name": "rxjs-labs",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "workspaces": [
    "packages/*",
    "apps/*",
    "docs"
  ],
  "main": "index.js",
  "scripts": {
    "docs:dev": "npm --workspace docs run dev",
    "docs:build": "npm --workspace docs run build",
    "docs:preview": "npm --workspace docs run preview",
    "dev:labs-web": "npm run dev --workspace apps/labs-web",
    "build:labs-web": "npm run build --workspace apps/labs-web",
    "preview:labs-web": "npm run preview --workspace apps/labs-web",
    "dev:rxjs-operator-log-point": "npm run dev --workspace apps/rxjs-operator-log-point",
    "build:rxjs-operator-log-point": "npm run build --workspace apps/rxjs-operator-log-point",
    "preview:rxjs-operator-log-point": "npm run preview --workspace apps/rxjs-operator-log-point",
    "dev:rxjs-dag-builder": "npm run dev --workspace apps/rxjs-dag-builder",
    "build:rxjs-dag-builder": "npm run build --workspace apps/rxjs-dag-builder",
    "preview:rxjs-dag-builder": "npm run preview --workspace apps/rxjs-dag-builder",
    "dev:rxjs-use-case-explorer": "npm run dev --workspace apps/rxjs-use-case-explorer",
    "build:rxjs-use-case-explorer": "npm run build --workspace apps/rxjs-use-case-explorer",
    "preview:rxjs-use-case-explorer": "npm run preview --workspace apps/rxjs-use-case-explorer",
    "dev:rxjs-web": "npm run dev --workspace apps/rxjs-web",
    "build:rxjs-web": "npm run build --workspace apps/rxjs-web",
    "preview:rxjs-web": "npm run preview --workspace apps/rxjs-web",
    "dev:rxjs-workflow-time-visual-text": "npm run dev --workspace apps/rxjs-workflow-time-visual-text",
    "build:rxjs-workflow-time-visual-text": "npm run build --workspace apps/rxjs-workflow-time-visual-text",
    "preview:rxjs-workflow-time-visual-text": "npm run preview --workspace apps/rxjs-workflow-time-visual-text",
    "test": "npm run test:packages",
    "test:packages": "npm --workspaces --if-present run test -- --runInBand",
    "build:packages": "npm --workspaces --if-present run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}

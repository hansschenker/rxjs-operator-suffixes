{
  "name": "rxjs-hono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:client": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.0",
    "@hono/zod-openapi": "^0.19.0",
    "@scalar/hono-api-reference": "~0.5.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.30.0",
    "drizzle-zod": "^0.5.0",
    "hono": "^4.3.0",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.21.0",
    "jsdom": "^24.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
